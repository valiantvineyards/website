---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";
import { Image } from "astro:assets";
import HeroImage from "../../components/HeroImage.astro";
import defaultImage from "../../assets/images/wine-bottles-with-medals-landscape.webp";
import heroImage from "../../assets/images/casks-in-cellar.webp";

const allJobs = await getCollection("jobs", ({ data }) => !data.draft);

const sortedJobs = allJobs.sort((a, b) => {
  if (a.data.pinned && !b.data.pinned) return -1;
  if (!a.data.pinned && b.data.pinned) return 1;
  return b.data.date.valueOf() - a.data.date.valueOf();
});
---

<BaseLayout
  title="Careers"
  description="Join our team at Valiant Vineyards Winery & Distillery. View open positions and apply today."
>
  <!-- Hero Section -->
  <section class="relative">
    <div class="relative min-h-[50vh] flex items-center justify-center py-24 bg-neutral-900">
      <HeroImage
        src={heroImage}
        alt="Oak casks aging in the wine cellar at Valiant Vineyards"
        widths={[640, 1024, 1536, 2048]}
        sizes="100vw"
        quality={30}
      />
      <div class="container relative mx-auto px-4 lg:px-8 text-center">
        <div class="inline-block bg-black/50 px-8 py-6">
          <h1 class="font-serif text-4xl font-semibold tracking-tight text-white sm:text-5xl lg:text-6xl">
            Careers
          </h1>
          <p class="mt-4 font-serif text-xl text-white font-medium max-w-2xl mx-auto lg:text-2xl">
            Join our team at Valiant Vineyards
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Jobs Grid -->
  <section class="py-12 lg:py-16">
    <div class="container mx-auto px-4 lg:px-8">
      {
        sortedJobs.length > 0 ? (
          <div class="grid gap-8 sm:grid-cols-2 lg:grid-cols-3">
            {sortedJobs.map((job) => {
              const image = job.data.featuredImage ?? defaultImage;
              const imageAlt = job.data.featuredImageAlt ?? job.data.title;
              const typeLabel = job.data.employmentType === "full-time" ? "Full-Time" : "Part-Time";

              return (
                <a
                  href={`/jobs/${job.id}/`}
                  class="group block bg-white overflow-hidden shadow-sm hover:shadow-lg transition-shadow duration-300"
                >
                  <div class="aspect-16/10 overflow-hidden relative">
                    <Image
                      src={image}
                      alt={imageAlt}
                      widths={[400, 600, 800]}
                      sizes="(max-width: 640px) 100vw, (max-width: 1024px) 50vw, 33vw"
                      class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
                    />
                    <span class="absolute top-3 right-3 bg-gold text-white text-sm font-medium px-3 py-1">
                      {typeLabel}
                    </span>
                  </div>
                  <div class="p-6">
                    <h2 class="font-serif text-xl font-semibold text-foreground group-hover:text-gold transition-colors">
                      {job.data.title}
                    </h2>
                    <div class="mt-2 flex flex-wrap items-center gap-x-4 gap-y-1 text-sm text-muted-foreground">
                      <span>{job.data.department}</span>
                      <span class="text-neutral-300">|</span>
                      <span>{job.data.wage}</span>
                    </div>
                    <p class="mt-3 text-muted-foreground line-clamp-2">
                      {job.data.description}
                    </p>
                  </div>
                </a>
              );
            })}
          </div>
        ) : (
          <div class="text-center py-16">
            <p class="text-lg text-muted-foreground">
              No open positions at this time. Check back soon!
            </p>
          </div>
        )
      }
    </div>
  </section>
</BaseLayout>

<style>
  .line-clamp-2 {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>
