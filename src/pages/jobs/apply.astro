---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";

const jobs = await getCollection("jobs", ({ data }) => !data.draft);
const jobOptions = jobs.map((job) => ({
  slug: job.id,
  title: job.data.title,
  ageRequirement: job.data.ageRequirement ?? null,
}));

const usStates = [
  "AL","AK","AZ","AR","CA","CO","CT","DE","FL","GA",
  "HI","ID","IL","IN","IA","KS","KY","LA","ME","MD",
  "MA","MI","MN","MS","MO","MT","NE","NV","NH","NJ",
  "NM","NY","NC","ND","OH","OK","OR","PA","RI","SC",
  "SD","TN","TX","UT","VT","VA","WA","WV","WI","WY",
];

const inputClasses = "w-full rounded-md border border-neutral-300 bg-white px-4 py-3 text-base transition-colors focus:border-gold focus:outline-none focus:ring-2 focus:ring-gold/20";
const labelClasses = "block text-sm font-medium mb-2";
const sectionClasses = "space-y-6";
---

<BaseLayout
  title="Apply | Careers"
  description="Apply for a position at Valiant Vineyards Winery & Distillery."
>
  <section class="py-12 lg:py-16">
    <div class="container mx-auto px-4 lg:px-8">
      <div class="mx-auto max-w-3xl">
        <header class="mb-10 text-center">
          <h1 class="font-serif text-3xl font-semibold tracking-tight text-foreground sm:text-4xl lg:text-5xl">
            Employment Application
          </h1>
          <p class="mt-4 text-muted-foreground">
            Fill out the form below to apply for a position at Valiant Vineyards.
          </p>
        </header>

        <form id="application-form" class="space-y-10" novalidate>
          <!-- Honeypot -->
          <input type="text" name="website" class="hidden" tabindex="-1" autocomplete="off" />

          <!-- Position -->
          <fieldset class={sectionClasses}>
            <legend class="font-serif text-xl font-semibold text-foreground mb-4">Position</legend>
            <div>
              <label for="position" class={labelClasses}>
                Position Applying For <span class="text-red-600" aria-hidden="true">*</span>
              </label>
              <select
                id="position"
                name="position"
                required
                aria-required="true"
                class={inputClasses}
                data-jobs={JSON.stringify(jobOptions)}
              >
                <option value="">Select a position...</option>
                {jobOptions.map((job) => (
                  <option
                    value={job.slug}
                    data-age-requirement={job.ageRequirement ?? ""}
                  >
                    {job.title}
                  </option>
                ))}
              </select>
            </div>
          </fieldset>

          <!-- Age Verification (conditional) -->
          <fieldset id="age-verification-section" class={`${sectionClasses} hidden`}>
            <legend class="font-serif text-xl font-semibold text-foreground mb-4">Age Verification</legend>
            <div class="flex items-start gap-3 rounded-md border border-amber-200 bg-amber-50 p-4">
              <input
                type="checkbox"
                id="ageConfirmation"
                name="ageConfirmation"
                value="yes"
                class="mt-0.5 h-5 w-5 rounded border-neutral-300 accent-gold focus:ring-gold/20"
              />
              <label for="ageConfirmation" class="text-sm text-foreground">
                I confirm that I am at least <span id="age-requirement-text">21</span> years of age. <span class="text-red-600" aria-hidden="true">*</span>
              </label>
            </div>
          </fieldset>

          <!-- Personal Information -->
          <fieldset class={sectionClasses}>
            <legend class="font-serif text-xl font-semibold text-foreground mb-4">Personal Information</legend>

            <div>
              <label for="fullName" class={labelClasses}>
                Full Name <span class="text-red-600" aria-hidden="true">*</span>
              </label>
              <input
                type="text"
                id="fullName"
                name="fullName"
                required
                aria-required="true"
                autocomplete="name"
                class={inputClasses}
                placeholder="Your full name"
              />
            </div>

            <div class="grid gap-6 sm:grid-cols-2">
              <div>
                <label for="phone" class={labelClasses}>
                  Phone <span class="text-red-600" aria-hidden="true">*</span>
                </label>
                <input
                  type="tel"
                  id="phone"
                  name="phone"
                  required
                  aria-required="true"
                  autocomplete="tel"
                  class={inputClasses}
                  placeholder="(555) 123-4567"
                />
              </div>
              <div>
                <label for="email" class={labelClasses}>
                  Email <span class="text-red-600" aria-hidden="true">*</span>
                </label>
                <input
                  type="email"
                  id="email"
                  name="email"
                  required
                  aria-required="true"
                  autocomplete="email"
                  class={inputClasses}
                  placeholder="you@example.com"
                />
              </div>
            </div>

            <div>
              <label for="streetAddress" class={labelClasses}>
                Street Address
              </label>
              <input
                type="text"
                id="streetAddress"
                name="streetAddress"
                autocomplete="street-address"
                class={inputClasses}
                placeholder="123 Main St"
              />
            </div>

            <div class="grid gap-6 sm:grid-cols-3">
              <div>
                <label for="city" class={labelClasses}>City</label>
                <input
                  type="text"
                  id="city"
                  name="city"
                  autocomplete="address-level2"
                  class={inputClasses}
                  placeholder="City"
                />
              </div>
              <div>
                <label for="state" class={labelClasses}>State</label>
                <select id="state" name="state" autocomplete="address-level1" class={inputClasses}>
                  <option value="">Select...</option>
                  {usStates.map((s) => (
                    <option value={s}>{s}</option>
                  ))}
                </select>
              </div>
              <div>
                <label for="zip" class={labelClasses}>ZIP Code</label>
                <input
                  type="text"
                  id="zip"
                  name="zip"
                  autocomplete="postal-code"
                  class={inputClasses}
                  placeholder="57001"
                />
              </div>
            </div>
          </fieldset>

          <!-- Availability -->
          <fieldset class={sectionClasses}>
            <legend class="font-serif text-xl font-semibold text-foreground mb-4">Availability</legend>

            <div>
              <label for="startDate" class={labelClasses}>Earliest Start Date</label>
              <input
                type="date"
                id="startDate"
                name="startDate"
                class={inputClasses}
              />
            </div>

            <div>
              <p class="text-sm font-medium mb-3">Preferred Schedule</p>
              <div class="flex flex-wrap gap-x-6 gap-y-3">
                {["Full-Time", "Part-Time", "Weekends", "Morning", "Evening"].map((schedule) => (
                  <div class="flex items-center gap-2">
                    <input
                      type="checkbox"
                      id={`schedule-${schedule.toLowerCase()}`}
                      name="schedule"
                      value={schedule}
                      class="h-5 w-5 rounded border-neutral-300 accent-gold focus:ring-gold/20"
                    />
                    <label for={`schedule-${schedule.toLowerCase()}`} class="text-sm">
                      {schedule}
                    </label>
                  </div>
                ))}
              </div>
            </div>
          </fieldset>

          <!-- Employment History -->
          <fieldset class={sectionClasses}>
            <legend class="font-serif text-xl font-semibold text-foreground mb-4">Employment History</legend>
            <p class="text-sm text-muted-foreground -mt-2 mb-4">Optional — list up to 2 previous positions.</p>

            {[1, 2].map((num) => (
              <div class="space-y-4 rounded-lg border border-neutral-200 p-5">
                <p class="text-sm font-semibold text-muted-foreground">Position {num}</p>
                <div class="grid gap-4 sm:grid-cols-2">
                  <div>
                    <label for={`employer${num}`} class={labelClasses}>Employer</label>
                    <input type="text" id={`employer${num}`} name={`employer${num}`} class={inputClasses} />
                  </div>
                  <div>
                    <label for={`jobTitle${num}`} class={labelClasses}>Position/Title</label>
                    <input type="text" id={`jobTitle${num}`} name={`jobTitle${num}`} class={inputClasses} />
                  </div>
                </div>
                <div>
                  <label for={`jobCityState${num}`} class={labelClasses}>City/State</label>
                  <input type="text" id={`jobCityState${num}`} name={`jobCityState${num}`} class={inputClasses} />
                </div>
                <div class="grid gap-4 sm:grid-cols-2">
                  <div>
                    <label for={`jobStart${num}`} class={labelClasses}>Start Date</label>
                    <input type="date" id={`jobStart${num}`} name={`jobStart${num}`} class={inputClasses} />
                  </div>
                  <div>
                    <label for={`jobEnd${num}`} class={labelClasses}>End Date</label>
                    <input type="date" id={`jobEnd${num}`} name={`jobEnd${num}`} class={inputClasses} />
                  </div>
                </div>
                <div>
                  <label for={`jobResponsibilities${num}`} class={labelClasses}>Responsibilities</label>
                  <textarea
                    id={`jobResponsibilities${num}`}
                    name={`jobResponsibilities${num}`}
                    rows={3}
                    class={`${inputClasses} resize-y`}
                  ></textarea>
                </div>
              </div>
            ))}
          </fieldset>

          <!-- Education -->
          <fieldset class={sectionClasses}>
            <legend class="font-serif text-xl font-semibold text-foreground mb-4">Education</legend>

            <div class="grid gap-6 sm:grid-cols-2">
              <div>
                <label for="schoolName" class={labelClasses}>School Name</label>
                <input type="text" id="schoolName" name="schoolName" class={inputClasses} />
              </div>
              <div>
                <label for="schoolCityState" class={labelClasses}>City/State</label>
                <input type="text" id="schoolCityState" name="schoolCityState" class={inputClasses} />
              </div>
            </div>

            <div>
              <label for="educationLevel" class={labelClasses}>Highest Level Completed</label>
              <select id="educationLevel" name="educationLevel" class={inputClasses}>
                <option value="">Select...</option>
                <option value="some-high-school">Some High School</option>
                <option value="high-school">High School Diploma / GED</option>
                <option value="some-college">Some College</option>
                <option value="associates">Associate's Degree</option>
                <option value="bachelors">Bachelor's Degree</option>
                <option value="masters">Master's Degree or Higher</option>
              </select>
            </div>

            <div>
              <label for="certifications" class={labelClasses}>
                Certifications <span class="text-muted-foreground font-normal">(optional)</span>
              </label>
              <textarea
                id="certifications"
                name="certifications"
                rows={3}
                class={`${inputClasses} resize-y`}
                placeholder="List any relevant certifications (e.g., ServSafe, Food Handler's Card)"
              ></textarea>
            </div>
          </fieldset>

          <!-- Skills -->
          <fieldset class={sectionClasses}>
            <legend class="font-serif text-xl font-semibold text-foreground mb-4">Skills</legend>

            <div>
              <p class="text-sm font-medium mb-3">Select all that apply</p>
              <div class="flex flex-wrap gap-x-6 gap-y-3">
                {["Cooking", "Food Preparation", "Customer Service", "Kitchen Cleaning", "Time Management"].map((skill) => (
                  <div class="flex items-center gap-2">
                    <input
                      type="checkbox"
                      id={`skill-${skill.toLowerCase().replace(/ /g, "-")}`}
                      name="skills"
                      value={skill}
                      class="h-5 w-5 rounded border-neutral-300 accent-gold focus:ring-gold/20"
                    />
                    <label for={`skill-${skill.toLowerCase().replace(/ /g, "-")}`} class="text-sm">
                      {skill}
                    </label>
                  </div>
                ))}
              </div>
            </div>

            <div>
              <label for="otherSkills" class={labelClasses}>
                Other Skills <span class="text-muted-foreground font-normal">(optional)</span>
              </label>
              <input
                type="text"
                id="otherSkills"
                name="otherSkills"
                class={inputClasses}
                placeholder="Any other relevant skills"
              />
            </div>
          </fieldset>

          <!-- References -->
          <fieldset class={sectionClasses}>
            <legend class="font-serif text-xl font-semibold text-foreground mb-4">References</legend>

            {[1, 2].map((num) => (
              <div class="space-y-4 rounded-lg border border-neutral-200 p-5">
                <p class="text-sm font-semibold text-muted-foreground">Reference {num}</p>
                <div class="grid gap-4 sm:grid-cols-3">
                  <div>
                    <label for={`refName${num}`} class={labelClasses}>Name</label>
                    <input type="text" id={`refName${num}`} name={`refName${num}`} class={inputClasses} />
                  </div>
                  <div>
                    <label for={`refPhone${num}`} class={labelClasses}>Phone</label>
                    <input type="tel" id={`refPhone${num}`} name={`refPhone${num}`} class={inputClasses} />
                  </div>
                  <div>
                    <label for={`refRelationship${num}`} class={labelClasses}>Relationship</label>
                    <input type="text" id={`refRelationship${num}`} name={`refRelationship${num}`} class={inputClasses} />
                  </div>
                </div>
              </div>
            ))}
          </fieldset>

          <!-- Resume Upload -->
          <fieldset class={sectionClasses}>
            <legend class="font-serif text-xl font-semibold text-foreground mb-4">Resume</legend>

            <div>
              <label for="resume" class={labelClasses}>
                Upload Resume <span class="text-muted-foreground font-normal">(PDF only, 5MB max)</span>
              </label>
              <input
                type="file"
                id="resume"
                name="resume"
                accept=".pdf"
                class="w-full text-sm text-muted-foreground file:mr-4 file:rounded-md file:border-0 file:bg-gold file:px-4 file:py-2 file:text-sm file:font-medium file:text-white file:cursor-pointer hover:file:bg-gold-dark"
              />
              <p id="resume-error" class="mt-2 text-sm text-red-600 hidden"></p>
            </div>
          </fieldset>

          <!-- Certification -->
          <fieldset class={sectionClasses}>
            <legend class="font-serif text-xl font-semibold text-foreground mb-4">Certification</legend>

            <div class="flex items-start gap-3">
              <input
                type="checkbox"
                id="certification"
                name="certification"
                value="yes"
                required
                aria-required="true"
                class="mt-0.5 h-5 w-5 rounded border-neutral-300 accent-gold focus:ring-gold/20"
              />
              <label for="certification" class="text-sm text-foreground">
                I certify that the information provided in this application is true and complete to the best of my knowledge. I understand that any falsification or omission of information may be grounds for rejection of my application or termination of employment. <span class="text-red-600" aria-hidden="true">*</span>
              </label>
            </div>
          </fieldset>

          <!-- Turnstile -->
          <div class="cf-turnstile" data-sitekey="0x4AAAAAACHr1kbpPYRV4EtW" data-theme="light" aria-label="Security verification"></div>

          <!-- Submit -->
          <div>
            <button
              type="submit"
              id="submit-btn"
              class="w-full rounded-md bg-gold px-6 py-3 text-sm font-medium text-white shadow transition-colors hover:bg-gold-dark sm:w-auto"
            >
              Submit Application
            </button>
          </div>

          <!-- Feedback -->
          <div id="form-message" class="hidden rounded-md p-4" aria-live="assertive" aria-atomic="true">
            <p id="form-message-text"></p>
          </div>
        </form>
      </div>
    </div>
  </section>

  <!-- Turnstile Script -->
  <script is:inline src="https://challenges.cloudflare.com/turnstile/v0/api.js" async defer></script>

  <script>
    const form = document.getElementById("application-form") as HTMLFormElement;
    const positionSelect = document.getElementById("position") as HTMLSelectElement;
    const ageSection = document.getElementById("age-verification-section") as HTMLElement;
    const ageCheckbox = document.getElementById("ageConfirmation") as HTMLInputElement;
    const ageText = document.getElementById("age-requirement-text") as HTMLElement;
    const resumeInput = document.getElementById("resume") as HTMLInputElement;
    const resumeError = document.getElementById("resume-error") as HTMLElement;
    const submitBtn = document.getElementById("submit-btn") as HTMLButtonElement;
    const messageContainer = document.getElementById("form-message") as HTMLElement;
    const messageText = document.getElementById("form-message-text") as HTMLElement;

    // Pre-select position from URL param
    const urlParams = new URLSearchParams(window.location.search);
    const positionParam = urlParams.get("position");
    if (positionParam && positionSelect) {
      const option = positionSelect.querySelector(`option[value="${positionParam}"]`);
      if (option) {
        positionSelect.value = positionParam;
        positionSelect.dispatchEvent(new Event("change"));
      }
    }

    // Age verification toggle
    positionSelect?.addEventListener("change", () => {
      const selected = positionSelect.options[positionSelect.selectedIndex];
      const ageReq = selected?.getAttribute("data-age-requirement");

      if (ageReq && ageReq !== "") {
        ageSection.classList.remove("hidden");
        ageCheckbox.required = true;
        ageText.textContent = ageReq;
      } else {
        ageSection.classList.add("hidden");
        ageCheckbox.required = false;
        ageCheckbox.checked = false;
      }
    });

    // File size validation
    resumeInput?.addEventListener("change", () => {
      const file = resumeInput.files?.[0];
      if (file) {
        if (file.size > 5 * 1024 * 1024) {
          resumeError.textContent = "File must be under 5MB.";
          resumeError.classList.remove("hidden");
          resumeInput.value = "";
        } else if (file.type !== "application/pdf") {
          resumeError.textContent = "Only PDF files are accepted.";
          resumeError.classList.remove("hidden");
          resumeInput.value = "";
        } else {
          resumeError.classList.add("hidden");
        }
      }
    });

    // Form submission
    form?.addEventListener("submit", async (e) => {
      e.preventDefault();

      // Client-side Turnstile check
      const turnstileResponse = form.querySelector('[name="cf-turnstile-response"]') as HTMLInputElement;
      if (!turnstileResponse || !turnstileResponse.value) {
        showMessage("Please complete the security check before submitting.", "error");
        return;
      }

      const originalText = submitBtn.textContent;
      submitBtn.disabled = true;
      submitBtn.textContent = "Submitting...";

      try {
        const formData = new FormData(form);
        const response = await fetch("/api/job-application", {
          method: "POST",
          body: formData,
        });

        const result = await response.json();

        if (result.success) {
          showMessage("Your application has been submitted successfully! We'll be in touch soon.", "success");
          form.reset();
          ageSection.classList.add("hidden");
          // Scroll to message
          messageContainer.scrollIntoView({ behavior: "smooth", block: "center" });
        } else {
          showMessage(result.error || "Something went wrong. Please try again.", "error");
        }
      } catch {
        showMessage("Failed to submit application. Please try again.", "error");
      }

      submitBtn.disabled = false;
      submitBtn.textContent = originalText;
    });

    function showMessage(message: string, type: "success" | "error") {
      messageContainer.classList.remove("hidden", "bg-green-50", "text-green-700", "bg-red-50", "text-red-700");
      if (type === "success") {
        messageContainer.classList.add("bg-green-50", "text-green-700");
      } else {
        messageContainer.classList.add("bg-red-50", "text-red-700");
      }
      messageText.textContent = message;
    }
  </script>
</BaseLayout>
